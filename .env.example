# ===========================================
# Nkabom Fund - Environment Variables
# ===========================================

# Paystack Payment Configuration
# Get your keys from https://dashboard.paystack.com
# Test keys start with pk_test_ and sk_test_
# Live keys start with pk_live_ and sk_live_

VITE_PAYSTACK_PUBLIC_KEY=pk_test_YOUR_PUBLIC_KEY_HERE
VITE_PAYSTACK_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# Payment Callback URL
VITE_PAYMENT_CALLBACK_URL=https://nkabomfund.vercel.app

# Platform Configuration
VITE_APP_NAME=Nkabom Fund
VITE_APP_URL=https://nkabomfund.vercel.app

# ===========================================
# Neon Database Configuration (PostgreSQL)
# Get your connection string from https://neon.tech
# Run: npx neonctl@latest init
# ===========================================

VITE_NEON_AUTH_URL=https://ep-floral-wave-amvtovtl.neonauth.c-5.us-east-1.aws.neon.tech/neondb/auth

# Full connection string from Neon
DATABASE_URL=postgresql://neondb_owner:npg_CiXZHJmI9v7k@ep-floral-wave-amvtovtl-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Individual connection details (optional)
NEON_HOST=your-project.neon.tech
NEON_DATABASE=your-database
NEON_USER=your-username
NEON_PASSWORD=your-password
NEON_SSL=true

# ===========================================
# Optional Services
# ===========================================

# Google Analytics
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Email Service (for receipts)
# VITE_EMAIL_SERVICE=sendgrid
# VITE_EMAIL_API_KEY=SG.xxxxxxxxxxxxxxxx
