# Paystack Payment Configuration
# Get your keys from https://dashboard.paystack.com
# Test keys start with pk_test_ and sk_test_
# Live keys start with pk_live_ and sk_live_

VITE_PAYSTACK_PUBLIC_KEY=pk_test_YOUR_PUBLIC_KEY_HERE
VITE_PAYSTACK_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# Payment Callback URL (where Paystack redirects after payment)
VITE_PAYMENT_CALLBACK_URL=https://your-domain.com

# Platform Configuration
VITE_APP_NAME=Nkabom Fund
VITE_APP_URL=https://your-domain.com

# Optional: Google Analytics
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Email Service (for receipts)
# VITE_EMAIL_SERVICE=sendgrid
# VITE_EMAIL_API_KEY=SG.xxxxxxxxxxxxxxxx
